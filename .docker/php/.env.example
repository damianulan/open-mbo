APP_NAME="OpenMBO"
APP_ENV=local
APP_LOCALE=pl
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:37000
APP_TIMEZONE='Europe/Warsaw'
APP_ENIGMA_MODELS=false

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=open-mbo
DB_USERNAME=laravel
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=300
SESSION_DOMAIN=
SESSION_ENCRYPTION=false
SESSION_SECURE_COOKIE=false
TELESCOPE_ENABLED=true
ACTIVITY_LOGGER_ENABLED=true
DEBUGBAR_ENABLED=true
COMPOSER_EXECUTABLE="composer update"

BACKUP_AUTO=false
BACKUP_ARCHIVE_PASSWORD=null
CRON_APP_REFRESH=false
CRON_RUN_TEST=false

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@open-mbo.test"
MAIL_HOST_ADDRESS="no-reply@open-mbo.test"
MAIL_FROM_NAME="${APP_NAME}"
MAILCATCHALL_ENABLED=true
MAILCATCHALL_RECEIVER="dev@open-mbo.test"

SETTINGS_CACHE_ENABLED=true

MODEL_CACHE_ENABLED=true #false for local
MODEL_CACHE_DEBUG=true #true when testing on local
PRUNE_SOFT_DELETES_DAYS=30

SCOUT_QUEUE=false

DATEFORMAT="d.m.Y"
TIMEFORMAT="H:i"

REDIS_HOST=redis
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
